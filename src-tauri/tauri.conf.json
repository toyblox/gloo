{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gloo",
  "version": "0.1.0",
  "identifier": "com.aliciachen.gloo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Gloo",
        "width": 400,
        "height": 550,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
